{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "~/*": [
        "./*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@clients/*": [
        "./src/clients/*"
      ],
      "@schema/*": [
        "./src/bun/api/schema/*"
      ],
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "vite-env-override.d.ts"
  ]
}